<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <!-- Connection -->
        <property name="hibernate.connection.driver_class"> org.postgresql.Driver </property>
        <property name="hibernate.connection.url"> jdbc:postgresql://localhost:5432/hibernate_tp2 </property>
        <property name="hibernate.connection.username">javauser</property>
        <property name="hibernate.connection.password">javauser</property>
        <property name="hibernate.dialect"> org.hibernate.dialect.PostgreSQLDialect </property>
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.hbm2ddl.auto">create</property>
        <mapping class="entity.Doctor" />
        <mapping class="entity.Patient" />
<!--        <mapping resource="com/example/entity/Class.hbm.xml"/>-->
    </session-factory>
</hibernate-configuration>
